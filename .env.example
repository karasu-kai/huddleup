# Optional — required on Hostinger so redeploys do not wipe user data.
# Use absolute paths OUTSIDE the git deploy folder.

# Personal codes, projects, sessions, lists
HUDDLEUP_DATA_DIR=/home/YOUR_USER/domains/huddleup.wtf/private/huddleup-data

# Item photos (optional; defaults to public/uploads inside deploy)
HUDDLEUP_UPLOADS_DIR=/home/YOUR_USER/domains/huddleup.wtf/private/huddleup-uploads
